rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Check if the user is authenticated via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Students: Allow authenticated users to read their own data. 
    // Restrict writes to admin/staff roles.
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Should be handled by a secure Admin environment
    }

    // Announcements: Read-only for everyone, writes restricted.
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAuthenticated(); 
      allow delete: if false; // Prevent client-side deletion
    }

    // Default: Require authentication for everything else
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}